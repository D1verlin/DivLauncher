# =============================================
# DivLauncher — шаблон переменных окружения
# =============================================
# Скопируйте этот файл в .env и заполните значения:
#   cp .env.example .env

# Ссылка на сервер авторизации (Web API / Yggdrasil)
# Для локального тестирования раскомментируйте строку ниже
# и запустите бэкенд: cd backend && npm start
# AUTH_SERVER=http://localhost:3000

# Рабочий сервер (замените на свой):
AUTH_SERVER=https://your-auth-server.example.com
